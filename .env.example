# Agora Credentials
# Console → Project Management → copy App ID and App certificate (primary certificate).
# Must be the SAME project where Conversational AI is enabled.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Agora Conversational AI (required for /agent/start — voice agent join)
# If you see "allocate failed, please check if the appid is valid":
#   - AGORA_APP_ID must match that project exactly (no spaces).
#   - Enable "Conversational AI" (or Real-time AI) for the project in the console.
#   - AGORA_CUSTOMER_ID + AGORA_CUSTOMER_SECRET = RESTful API credentials
#     (Console → your account / RESTful API — NOT the App certificate).
AGORA_CONVO_AI_BASE_URL=https://api.agora.io
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# LLM Provider (used inside Agora ConvoAI agent config)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# TTS Provider — pick one
# ElevenLabs: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Toggle between male/female doctor voice in the UI
ELEVENLABS_VOICE_ID_MALE=pNInz6obpgDQGcFmaJgB
ELEVENLABS_VOICE_ID_FEMALE=21m00Tcm4TlvDq8ikWAM
# Premium "sexy doctor" voices 😏
ELEVENLABS_VOICE_ID_PREMIUM_MALE=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_VOICE_ID_PREMIUM_FEMALE=pMsXgVXv3BLzUgSXRplE
# Optional: same model for landing-page previews and Agora Convo AI TTS (default eleven_flash_v2_5)
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# Landing previews for中文 / Melayu / Tamil use multilingual + language_code (override if needed):
# ELEVENLABS_PREVIEW_I18N_MODEL=eleven_multilingual_v2
# ELEVENLABS_PREVIEW_OUTPUT_FORMAT=mp3_44100_128

# Cartesia (alternative TTS): https://play.cartesia.ai/keys
CARTESIA_API_KEY=

# Anam AI Avatar (optional — enables live animated doctor avatar via Agora Conversational AI)
# Sign up at https://anam.ai → Dashboard → API Keys
# Default avatar_id below is Anam's public demo avatar; replace with one from your dashboard.
ANAM_API_KEY=
ANAM_AVATAR_ID=960f614f-ea88-47c3-9883-f02094f70874

# Couchbase (Hackathon Sponsor)
# Sign up at https://cloud.couchbase.com
COUCHBASE_CONNECTION_STRING=couchbases://cb.h6rujpcmpjgqdmq.cloud.couchbase.com
COUCHBASE_USERNAME=medivoice_admin
COUCHBASE_PASSWORD=Medivoice2026!
COUCHBASE_BUCKET=medivoice

# Backend server config
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Environment
NODE_ENV=development
